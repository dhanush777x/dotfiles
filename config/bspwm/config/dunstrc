[global]
monitor = 0
follow = mouse

width = (260, 320)
height = (70, 300)
origin = top-right
offset = (15, 50)
scale = 0
notification_limit = 5

# Appearance - sleek and minimal
indicate_hidden = yes
transparency = 8
corner_radius = 12
gap_size = 8
separator_height = 0
separator_color = "auto"
padding = 14
horizontal_padding = 16
text_icon_padding = 10

# Frame
frame_width = 1
frame_color = "#45475A"

# Sorting and behavior
sort = yes
idle_threshold = 120

font = SF Pro Text 10
line_height = 0
markup = full
format = "<span weight='bold'>%s</span>\n%b"
alignment = left
vertical_alignment = center
content_alignment = center
show_age_threshold = 60
ellipsize = end
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes

enable_recursive_icon_lookup = true
icon_theme = "Papirus-Dark, Adwaita"
icon_position = left
min_icon_size = 24
max_icon_size = 32
icon_corner_radius = 6

# History
sticky_history = yes
history_length = 30

# Browser
browser = /usr/bin/xdg-open
always_run_script = true
ignore_dbusclose = false
force_xinerama = false

mouse_left_click = do_action, close_current
mouse_middle_click = close_current
mouse_right_click = close_all

# Progress bar 
progress_bar = true
progress_bar_height = 8
progress_bar_frame_width = 1
progress_bar_min_width = 280
progress_bar_max_width = 320
progress_bar_corner_radius = 4

# Window properties
title = Dunst
class = Dunst

[urgency_low]
timeout = 3
background = "#1E1E2E"
foreground = "#A6E3A1"

[urgency_normal]
timeout = 5
background = "#1E1E2E"
foreground = "#CDD6F4"

[urgency_critical]
timeout = 0
background = "#1E1E2E"
foreground = "#F38BA8"
