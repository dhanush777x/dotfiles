
configuration {

    kb-accept-entry: "Return,Control+m";

    kb-remove-to-eol: "";

    kb-row-down: "Control+j,Down";
    kb-row-up:   "Control+k,Up";

    kb-remove-char-back: "";
    kb-mode-complete: "";

    kb-row-left:  "Control+h";
    kb-row-right: "Control+l";

    kb-tab: "";
    kb-backtab: "";
}
